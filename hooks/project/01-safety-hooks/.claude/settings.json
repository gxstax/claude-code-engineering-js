{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/block-dangerous.sh"
          }
        ]
      },
      { 
        "matcher": "Write|Edit", 
        "hooks": [ 
            { 
                "type": "command", 
                "command": "./hooks/protect-files.sh" 
            } 
        ] 
    }
    ]
  }
}