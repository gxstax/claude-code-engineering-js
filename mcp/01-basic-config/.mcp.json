{
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@modelcontextprotocol/server-filesystem",
        "."
      ]
    },
    "fetch": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ]
    },
    "memory": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@modelcontextprotocol/server-memory"
      ]
    },
    "database": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@nilsir/mcp-server-mysql", "mysql://root:gao5219999@localhost:3306/damai_ticket"],
      "description": "MySQL 数据库——执行 SQL 查询"
    }
  }
}